# ============================================================
# Measy MissCall — GCP Production Environment Variables
# ============================================================
# Copy this file and fill in real values.
# These get stored in Google Secret Manager, NOT as plain env vars.
# The deploy script references them from Secret Manager automatically.
# ============================================================

# ── Database (Cloud SQL) ────────────────────────────────────
# Format: postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE&connection_limit=5
DATABASE_URL=""

# Read replica (optional — falls back to DATABASE_URL)
# DATABASE_READ_REPLICA_URL=""

# ── Auth ────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://your-domain.com"

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Twilio (optional — can be set via admin Platform Settings) ──
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# ── Cron Jobs ───────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=""

# ── Encryption ──────────────────────────────────────────────
# Generate: openssl rand -hex 32
# WARNING: Changing this after launch makes encrypted data unrecoverable
ENCRYPTION_KEY=""

# ── Google Cloud Storage ────────────────────────────────────
GCS_BUCKET_NAME="measy-uploads"

# ── Redis (Memorystore) ────────────────────────────────────
# Format: redis://INTERNAL_IP:6379
REDIS_URL=""

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_NAME="Measy MissCall"

# ── Seed Passwords (only needed for initial setup) ──────────
# SEED_ADMIN_PASSWORD=""
# SEED_OWNER_PASSWORD=""

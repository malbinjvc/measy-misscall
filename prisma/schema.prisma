generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  TENANT_OWNER
  TENANT_STAFF
}

enum TenantStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum CallStatus {
  MISSED
  ANSWERED
  FAILED
  BUSY
  NO_ANSWER
}

enum IvrResponse {
  CALLBACK
  BOOKING_LINK
  COMPLAINT
  NO_RESPONSE
  INVALID
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentPreference {
  DROP_OFF
  WAIT_FOR_IT
  PICKUP_DROPOFF
}

enum SmsStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  UNDELIVERED
}

enum SmsType {
  BOOKING_LINK
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  OTP_VERIFICATION
  CUSTOM
  CAMPAIGN
}

enum CampaignStatus {
  DRAFT
  SENDING
  COMPLETED
  FAILED
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  SKIPPED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum OnboardingStep {
  BUSINESS_PROFILE
  INDUSTRY
  SUBSCRIPTION
  REVIEW
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Models ──────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  password       String
  phone          String?
  role           UserRole  @default(TENANT_OWNER)
  emailVerified  DateTime?
  image          String?
  tenantId               String?
  tenant                 Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  impersonatingTenantId  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([tenantId])
  @@index([email])
}

model StaffInvite {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String
  name      String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([tenantId, email])
  @@index([token])
}

model Tenant {
  id                  String         @id @default(cuid())
  name                String
  slug                String         @unique
  email               String
  phone               String?
  phoneVerified       Boolean        @default(false)
  address             String?
  city                String?
  state               String?
  zipCode             String?
  country             String?        @default("CA")
  logoUrl             String?
  description         String?
  industry            String?
  website             String?
  status              TenantStatus   @default(ONBOARDING)
  onboardingStep      OnboardingStep @default(BUSINESS_PROFILE)

  // Phone Configuration
  assignedTwilioNumber String?       @unique
  businessPhoneNumber  String?       @unique
  ivrGreeting          String?        @default("Thank you for calling. We missed your call.")
  ivrCallbackMessage   String?        @default("Press 1 if you would like us to call you back.")
  ivrAudioUrl          String?
  // Stripe
  stripeCustomerId    String?        @unique

  // Appointment Settings
  autoConfirmAppointments Boolean @default(false)
  maxConcurrentBookings   Int     @default(1) // concurrent bookings per time slot

  // Social Media
  facebookUrl         String?
  instagramUrl        String?
  mapUrl              String?

  // Hero Media
  heroMediaUrl        String?
  heroMediaType       String?        @default("image") // "image" or "video"

  // Website Builder
  websiteConfig       Json?

  // Custom Domain (white-label)
  customDomain         String?  @unique
  customDomainVerified Boolean  @default(false)

  // Relations
  users               User[]
  services            Service[]
  calls               Call[]
  appointments        Appointment[]
  smsLogs             SmsLog[]
  businessHours       BusinessHours[]
  subscription        Subscription?
  reviews             Review[]
  customers           Customer[]
  supportTickets      SupportTicket[]
  wallet              Wallet?
  campaigns           Campaign[]
  staffInvites        StaffInvite[]

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([slug])
  @@index([status])
}

model Service {
  id               String            @id @default(cuid())
  name             String
  description      String?
  duration         Int               @default(60) // in minutes
  price            Decimal?          @db.Decimal(10, 2)
  isActive         Boolean           @default(true)
  sortOrder        Int               @default(0)
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  appointmentItems AppointmentItem[]
  options          ServiceOption[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tenantId])
}

model ServiceOption {
  id               String             @id @default(cuid())
  name             String
  description      String?
  duration         Int?               // Override parent service duration (optional)
  price            Decimal?           @db.Decimal(10, 2) // Override parent service price (optional)
  isActive         Boolean            @default(true)
  sortOrder        Int                @default(0)
  defaultQuantity  Int                @default(1)
  minQuantity      Int                @default(1)
  maxQuantity      Int                @default(10)
  serviceId        String
  service          Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  appointmentItems AppointmentItem[]
  subOptions       ServiceSubOption[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([serviceId])
}

model ServiceSubOption {
  id              String        @id @default(cuid())
  name            String
  description     String?
  price           Decimal?      @db.Decimal(10, 2)
  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)
  serviceOptionId String
  serviceOption   ServiceOption @relation(fields: [serviceOptionId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([serviceOptionId])
}

model Call {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  twilioCallSid   String?     @unique
  callerNumber    String
  callerName      String?
  status          CallStatus  @default(MISSED)
  ivrResponse     IvrResponse @default(NO_RESPONSE)
  ivrDigit        String?
  duration        Int?        // in seconds
  recordingUrl    String?
  smsLogs         SmsLog[]
  callbackHandled Boolean     @default(false)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // tenantId is leading column in all compound indexes below — no standalone @@index([tenantId]) needed
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, ivrResponse, callbackHandled])
  @@index([tenantId, callerNumber])  // customer activity: calls by phone within tenant
  @@index([callerNumber])
  @@index([createdAt])
  @@index([status])
}

model Appointment {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceOptionId    String?
  serviceOption      ServiceOption?    @relation(fields: [serviceOptionId], references: [id], onDelete: SetNull)
  quantity           Int               @default(1)
  selectedSubOptions String[]          // Array of ServiceSubOption IDs
  items              AppointmentItem[]
  customerName       String
  customerPhone   String
  customerEmail   String?
  date            DateTime
  startTime       String            // "09:00"
  endTime         String            // "10:00"
  status          AppointmentStatus @default(PENDING)
  notes           String?
  vehicleYear    String?
  vehicleType    String?
  vehicleMake    String?
  vehicleModel   String?
  appointmentPreference  AppointmentPreference?
  smsConsent      Boolean           @default(false)
  reminderSentAt  DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // tenantId is leading column in compound indexes — no standalone @@index([tenantId]) needed
  // (tenantId, date) is prefix of (tenantId, date, status) — no standalone needed
  @@index([tenantId, status])
  @@index([tenantId, date, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, customerPhone])
  @@index([status, reminderSentAt, date]) // cron reminder query: status + no reminder + date range
  @@index([date])                         // cross-tenant date range queries (cron fallback)
  @@index([customerPhone])
}

model AppointmentItem {
  id                 String         @id @default(cuid())
  appointmentId      String
  appointment        Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId          String?
  service            Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  serviceOptionId    String?
  serviceOption      ServiceOption? @relation(fields: [serviceOptionId], references: [id], onDelete: SetNull)
  quantity           Int            @default(1)
  selectedSubOptions String[]
  sortOrder          Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([appointmentId])
}

model SmsLog {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId          String?
  call            Call?     @relation(fields: [callId], references: [id], onDelete: SetNull)
  twilioMessageSid String?  @unique
  toNumber        String
  fromNumber      String
  body            String
  type            SmsType   @default(CUSTOM)
  status          SmsStatus @default(QUEUED)
  errorCode       String?
  errorMessage    String?
  sentAt          DateTime  @default(now())
  deliveredAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // tenantId is leading column in compound indexes — no standalone @@index([tenantId]) needed
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, status, createdAt]) // lazy-sync query: tenantId + QUEUED/SENT status + createdAt filter
  @@index([tenantId, toNumber])          // customer activity: SMS by phone within tenant
  @@index([callId])
  @@index([status])
}

model BusinessHours {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  day        DayOfWeek
  isOpen     Boolean   @default(true)
  openTime   String    @default("09:00")
  closeTime  String    @default("17:00")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, day])
  @@index([tenantId])
}

model Plan {
  id                String         @id @default(cuid())
  name              String
  description       String?
  price             Decimal     @default(0) @db.Decimal(10, 2)
  interval          String         @default("month") // "month" or "year"
  stripePriceId          String?   @unique  // Annual billing Stripe price
  monthlyStripePriceId   String?   @unique  // Monthly billing Stripe price (+$30 premium)
  maxCalls               Int       @default(100)
  maxSms            Int            @default(100)
  maxServices       Int            @default(10)
  maxStaff          Int            @default(3)
  features          String[]       @default([])
  isActive          Boolean        @default(true)
  sortOrder         Int            @default(0)
  subscriptions     Subscription[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan               @relation(fields: [planId], references: [id])
  stripeSubscriptionId  String?            @unique
  stripePriceId         String?
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([tenantId])
  @@index([status])
}

model PlatformSettings {
  id                    String   @id @default("platform-settings")
  // Shared Twilio
  sharedTwilioSid       String?
  sharedTwilioToken     String?
  sharedTwilioNumber    String?
  // Default IVR Messages
  defaultIvrGreeting    String?  @default("Thank you for calling. We missed your call.")
  defaultIvrCallback    String?  @default("Press 1 if you would like us to call you back.")
  // Stripe
  stripeSecretKey       String?
  stripePublishableKey  String?
  stripeWebhookSecret   String?
  // ElevenLabs TTS
  elevenlabsApiKey      String?
  elevenlabsVoiceId     String?
  // Dashboard Banner (shown on tenant overview page)
  dashboardBannerUrl    String?
  dashboardBannerType   String?  @default("image") // "image" or "video"
  dashboardBannerLink   String?
  dashboardBannerEnabled Boolean @default(false)
  // General
  maintenanceMode       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Review {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerName    String
  customerPhone   String?
  rating          Int      // 1-5
  comment         String?
  imageUrl        String?
  imageUrls       String[]
  importSource    String?
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, isVerified, createdAt]) // public reviews query: tenant + verified + order by date
  @@index([rating])
}

model PhoneVerification {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([phone, createdAt])
  @@index([expiresAt, verified]) // cleanup cron: find expired + unverified records
}

model TwilioCleanupQueue {
  id           String   @id @default(cuid())
  phoneNumber  String
  tenantId     String?
  tenantName   String?
  reason       String              // "tenant_deletion", "status_change_to_SUSPENDED", etc.
  attempts     Int      @default(0)
  maxAttempts  Int      @default(3)
  lastError    String?
  status       String   @default("PENDING")  // PENDING, COMPLETED, ABANDONED
  nextRetryAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, nextRetryAt])
}

model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String?
  smsConsent   Boolean  @default(false)
  vehicleYear  String?
  vehicleMake  String?
  vehicleModel String?
  vehicleType  String?
  notes        String?
  vehicles     CustomerVehicle[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, phone]) // unique constraint creates index with tenantId as leading column
  @@index([phone])
}

model CustomerVehicle {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleYear  String
  vehicleType  String?
  vehicleMake  String
  vehicleModel String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([customerId, vehicleYear, vehicleMake, vehicleModel])
  @@index([customerId])
}

model SupportTicket {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subject     String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  lastReadByAdmin  DateTime?
  lastReadByTenant DateTime?
  messages    TicketMessage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId, status, updatedAt]) // tenant ticket list: filter by tenant + status, order by updatedAt
  @@index([status, updatedAt])           // admin ticket list: filter by status, order by updatedAt
  @@index([createdAt])
}

model TicketMessage {
  id              String        @id @default(cuid())
  ticketId        String
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderRole      String        // "TENANT" or "ADMIN"
  senderName      String
  message         String
  attachmentUrls  String[]
  attachmentNames String[]
  createdAt       DateTime      @default(now())

  @@index([ticketId, createdAt]) // unread count queries: messages per ticket ordered by date
}

model Wallet {
  id                String              @id @default(cuid())
  tenantId          String              @unique
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  balance           Decimal             @default(0) @db.Decimal(10, 4)
  autoRecharge      Boolean             @default(true)
  rechargeThreshold Decimal             @default(10) @db.Decimal(10, 2)
  rechargeAmount    Decimal             @default(50) @db.Decimal(10, 2)
  // Atomic usage counters — reset each billing period
  usedSms           Int                 @default(0)
  usedCalls         Int                 @default(0)
  periodStart       DateTime?           // tracks which period the counters belong to
  // Prevent concurrent auto-recharges
  recharging        Boolean             @default(false)
  transactions      WalletTransaction[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([tenantId])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        String   // "RECHARGE", "SMS_CHARGE", "CALL_CHARGE", "INITIAL_LOAD", "MANUAL_RECHARGE"
  amount      Decimal  @db.Decimal(10, 4) // positive for credits, negative for charges
  balance     Decimal  @db.Decimal(10, 4) // balance after transaction
  description String?
  stripePaymentIntentId String?
  createdAt   DateTime @default(now())

  @@index([walletId])
  @@index([createdAt])
}

model AdminLog {
  id         String   @id @default(cuid())
  action     String                        // e.g. "TENANT_DELETED", "TWILIO_NUMBER_RELEASED"
  details    String?                       // Human-readable description
  tenantId   String?                       // Which tenant was affected (nullable for non-tenant actions)
  tenantName String?                       // Store name at time of action (tenant may be deleted)
  userId     String?                       // Admin who performed the action
  userName   String?                       // Store name at time of action
  status     String   @default("SUCCESS")  // "SUCCESS" or "FAILED"
  metadata   Json?                         // Extra data (phone numbers, error messages, etc.)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
}

model Campaign {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  message         String
  status          CampaignStatus   @default(DRAFT)
  recipientCount  Int              @default(0)
  sentCount       Int              @default(0)
  failedCount     Int              @default(0)
  createdAt       DateTime         @default(now())
  sentAt          DateTime?
  completedAt     DateTime?
  recipients      CampaignRecipient[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model CampaignRecipient {
  id           String                   @id @default(cuid())
  campaignId   String
  campaign     Campaign                 @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerName String?
  phone        String
  status       CampaignRecipientStatus  @default(PENDING)
  smsLogId     String?
  errorMessage String?
  sentAt       DateTime?

  @@index([campaignId, status])
}

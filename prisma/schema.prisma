generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  TENANT_OWNER
  TENANT_STAFF
}

enum TenantStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum CallStatus {
  MISSED
  ANSWERED
  FAILED
  BUSY
  NO_ANSWER
}

enum IvrResponse {
  CALLBACK
  BOOKING_LINK
  COMPLAINT
  NO_RESPONSE
  INVALID
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentPreference {
  DROP_OFF
  WAIT_FOR_IT
  PICKUP_DROPOFF
}

enum SmsStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  UNDELIVERED
}

enum SmsType {
  BOOKING_LINK
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  OTP_VERIFICATION
  CUSTOM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum OnboardingStep {
  BUSINESS_PROFILE
  INDUSTRY
  SUBSCRIPTION
  REVIEW
}

// ─── Models ──────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  password       String
  phone          String?
  role           UserRole  @default(TENANT_OWNER)
  emailVerified  DateTime?
  image          String?
  tenantId       String?
  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
  @@index([email])
}

model Tenant {
  id                  String         @id @default(cuid())
  name                String
  slug                String         @unique
  email               String
  phone               String?
  phoneVerified       Boolean        @default(false)
  address             String?
  city                String?
  state               String?
  zipCode             String?
  country             String?        @default("CA")
  logoUrl             String?
  description         String?
  industry            String?
  website             String?
  status              TenantStatus   @default(ONBOARDING)
  onboardingStep      OnboardingStep @default(BUSINESS_PROFILE)

  // Phone Configuration
  assignedTwilioNumber String?       @unique
  businessPhoneNumber  String?       @unique
  ivrGreeting          String?        @default("Thank you for calling. We missed your call.")
  ivrCallbackMessage   String?        @default("Press 1 if you would like us to call you back.")
  ivrAudioUrl          String?
  // Stripe
  stripeCustomerId    String?        @unique

  // Appointment Settings
  autoConfirmAppointments Boolean @default(false)

  // Social Media
  facebookUrl         String?
  instagramUrl        String?

  // Hero Media
  heroMediaUrl        String?
  heroMediaType       String?        @default("image") // "image" or "video"

  // Website Builder
  websiteConfig       Json?

  // Relations
  users               User[]
  services            Service[]
  calls               Call[]
  appointments        Appointment[]
  smsLogs             SmsLog[]
  businessHours       BusinessHours[]
  subscription        Subscription?
  reviews             Review[]
  customers           Customer[]

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([slug])
  @@index([status])
}

model Service {
  id               String            @id @default(cuid())
  name             String
  description      String?
  duration         Int               @default(60) // in minutes
  price            Decimal?          @db.Decimal(10, 2)
  isActive         Boolean           @default(true)
  sortOrder        Int               @default(0)
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  appointmentItems AppointmentItem[]
  options          ServiceOption[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tenantId])
}

model ServiceOption {
  id               String             @id @default(cuid())
  name             String
  description      String?
  duration         Int?               // Override parent service duration (optional)
  price            Decimal?           @db.Decimal(10, 2) // Override parent service price (optional)
  isActive         Boolean            @default(true)
  sortOrder        Int                @default(0)
  defaultQuantity  Int                @default(1)
  minQuantity      Int                @default(1)
  maxQuantity      Int                @default(10)
  serviceId        String
  service          Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  appointmentItems AppointmentItem[]
  subOptions       ServiceSubOption[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([serviceId])
}

model ServiceSubOption {
  id              String        @id @default(cuid())
  name            String
  description     String?
  price           Decimal?      @db.Decimal(10, 2)
  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)
  serviceOptionId String
  serviceOption   ServiceOption @relation(fields: [serviceOptionId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([serviceOptionId])
}

model Call {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  twilioCallSid   String?     @unique
  callerNumber    String
  callerName      String?
  status          CallStatus  @default(MISSED)
  ivrResponse     IvrResponse @default(NO_RESPONSE)
  ivrDigit        String?
  duration        Int?        // in seconds
  recordingUrl    String?
  smsLogs         SmsLog[]
  callbackHandled Boolean     @default(false)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantId])
  @@index([callerNumber])
  @@index([createdAt])
  @@index([status])
}

model Appointment {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         Service?          @relation(fields: [serviceId], references: [id])
  serviceOptionId    String?
  serviceOption      ServiceOption?    @relation(fields: [serviceOptionId], references: [id])
  quantity           Int               @default(1)
  selectedSubOptions String[]          // Array of ServiceSubOption IDs
  items              AppointmentItem[]
  customerName       String
  customerPhone   String
  customerEmail   String?
  date            DateTime
  startTime       String            // "09:00"
  endTime         String            // "10:00"
  status          AppointmentStatus @default(PENDING)
  notes           String?
  vehicleYear    String?
  vehicleType    String?
  vehicleMake    String?
  vehicleModel   String?
  appointmentPreference  AppointmentPreference?
  smsConsent      Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([tenantId])
  @@index([date])
  @@index([status])
  @@index([customerPhone])
}

model AppointmentItem {
  id                 String         @id @default(cuid())
  appointmentId      String
  appointment        Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId          String
  service            Service        @relation(fields: [serviceId], references: [id])
  serviceOptionId    String?
  serviceOption      ServiceOption? @relation(fields: [serviceOptionId], references: [id])
  quantity           Int            @default(1)
  selectedSubOptions String[]
  sortOrder          Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([appointmentId])
}

model SmsLog {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId          String?
  call            Call?     @relation(fields: [callId], references: [id])
  twilioMessageSid String?  @unique
  toNumber        String
  fromNumber      String
  body            String
  type            SmsType   @default(CUSTOM)
  status          SmsStatus @default(QUEUED)
  errorCode       String?
  errorMessage    String?
  sentAt          DateTime  @default(now())
  deliveredAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([callId])
  @@index([status])
}

model BusinessHours {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  day        DayOfWeek
  isOpen     Boolean   @default(true)
  openTime   String    @default("09:00")
  closeTime  String    @default("17:00")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, day])
  @@index([tenantId])
}

model Plan {
  id                String         @id @default(cuid())
  name              String
  description       String?
  price             Decimal     @default(0) @db.Decimal(10, 2)
  interval          String         @default("month") // "month" or "year"
  stripePriceId     String?        @unique
  maxCalls          Int            @default(100)
  maxSms            Int            @default(100)
  maxServices       Int            @default(10)
  maxStaff          Int            @default(3)
  features          String[]       @default([])
  isActive          Boolean        @default(true)
  sortOrder         Int            @default(0)
  subscriptions     Subscription[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan               @relation(fields: [planId], references: [id])
  stripeSubscriptionId  String?            @unique
  stripePriceId         String?
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([tenantId])
  @@index([status])
}

model PlatformSettings {
  id                    String   @id @default("platform-settings")
  // Shared Twilio
  sharedTwilioSid       String?
  sharedTwilioToken     String?
  sharedTwilioNumber    String?
  // Default IVR Messages
  defaultIvrGreeting    String?  @default("Thank you for calling. We missed your call.")
  defaultIvrCallback    String?  @default("Press 1 if you would like us to call you back.")
  // Stripe
  stripeSecretKey       String?
  stripePublishableKey  String?
  stripeWebhookSecret   String?
  // ElevenLabs TTS
  elevenlabsApiKey      String?
  elevenlabsVoiceId     String?
  // General
  maintenanceMode       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Review {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerName    String
  customerPhone   String
  rating          Int      // 1-5
  comment         String?
  imageUrl        String?
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([rating])
}

model PhoneVerification {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
}

model TwilioCleanupQueue {
  id           String   @id @default(cuid())
  phoneNumber  String
  tenantId     String?
  tenantName   String?
  reason       String              // "tenant_deletion", "status_change_to_SUSPENDED", etc.
  attempts     Int      @default(0)
  maxAttempts  Int      @default(3)
  lastError    String?
  status       String   @default("PENDING")  // PENDING, COMPLETED, ABANDONED
  nextRetryAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, nextRetryAt])
}

model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String?
  smsConsent   Boolean  @default(false)
  vehicleYear  String?
  vehicleMake  String?
  vehicleModel String?
  vehicleType  String?
  notes        String?
  vehicles     CustomerVehicle[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([phone])
}

model CustomerVehicle {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleYear  String
  vehicleType  String?
  vehicleMake  String
  vehicleModel String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([customerId, vehicleYear, vehicleMake, vehicleModel])
  @@index([customerId])
}

model AdminLog {
  id         String   @id @default(cuid())
  action     String                        // e.g. "TENANT_DELETED", "TWILIO_NUMBER_RELEASED"
  details    String?                       // Human-readable description
  tenantId   String?                       // Which tenant was affected (nullable for non-tenant actions)
  tenantName String?                       // Store name at time of action (tenant may be deleted)
  userId     String?                       // Admin who performed the action
  userName   String?                       // Store name at time of action
  status     String   @default("SUCCESS")  // "SUCCESS" or "FAILED"
  metadata   Json?                         // Extra data (phone numbers, error messages, etc.)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
}

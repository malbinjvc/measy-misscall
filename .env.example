# Database
# Production: add ?connection_limit=10&pool_timeout=30 for serverless environments
# With PgBouncer: add &pgbouncer=true to enable Prisma's PgBouncer-compatible mode
DATABASE_URL="postgresql://user:password@localhost:5432/measy_misscall?schema=public"

# Read replica (optional — for scaling read-heavy queries across replicas)
# Falls back to DATABASE_URL if not set. Use the same format as DATABASE_URL.
# DATABASE_READ_REPLICA_URL="postgresql://user:password@read-replica:5432/measy_misscall?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Twilio (optional — can also be set via admin Platform Settings)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cron job authentication — generate with: openssl rand -hex 32
CRON_SECRET=""

# Seed passwords (used by prisma/seed.ts)
SEED_ADMIN_PASSWORD=""
SEED_OWNER_PASSWORD=""

# Encryption key for secrets at rest — generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# Google Cloud Storage (production file uploads — falls back to local disk if not set)
# GCS_BUCKET_NAME="measy-uploads"

# Redis (production rate limiting + shared state — falls back to in-memory if not set)
# REDIS_URL="redis://10.0.0.1:6379"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Measy MissCall"
